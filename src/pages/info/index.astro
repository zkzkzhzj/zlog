---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Info — zlog">
  <h1 class="mb-10 text-2xl font-semibold">Info</h1>
  <div class="space-y-6 text-[15px] leading-relaxed text-gray-600">
    <p>
      안녕하세요, <strong class="text-gray-900">이무진(zkzkzhzj)</strong>입니다.
    </p>
    <p>개인적인 생각, 하고 싶은 것들을 올립니다.</p>

    <div class="pt-4">
      <h2 class="mb-3 text-lg font-medium text-gray-900">Contact</h2>
      <ul class="space-y-1 text-sm text-gray-500">
        <li>
          GitHub — <a
            href="https://github.com/zkzkzhzj"
            class="underline underline-offset-2 hover:text-gray-700"
            target="_blank"
            rel="noopener noreferrer">@zkzkzhzj</a>
        </li>
        <li>
          LinkedIn — <a
            href="https://www.linkedin.com/in/%EB%AC%B4%EC%A7%84-%EC%9D%B4-157354194/"
            class="underline underline-offset-2 hover:text-gray-700"
            target="_blank"
            rel="noopener noreferrer">이무진</a>
        </li>
        <li>
          X — <a
            href="https://x.com/zkzkzhzj"
            class="underline underline-offset-2 hover:text-gray-700"
            target="_blank"
            rel="noopener noreferrer">@zkzkzhzj</a>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
