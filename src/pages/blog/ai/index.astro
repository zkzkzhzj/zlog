---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCategoryTabs from "../../../components/BlogCategoryTabs.astro";
import NewBadge from "../../../components/NewBadge.astro";
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import { getBlogSlug, isPostCategory } from "../../../utils/content";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const posts = (await getCollection("blog"))
  .filter((post) => isPostCategory(post, "ai") && !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="AI · zlog">
  <h1 class="mb-6 text-2xl font-semibold">Blog</h1>

  <BlogCategoryTabs active="ai" />

  {
    posts.length > 0 ? (
      <ul class="flex flex-col gap-1">
        {posts.map((post) => (
          <li>
            <a
              href={`${base}blog/${getBlogSlug(post.id)}/`}
              class="group flex items-baseline justify-between gap-4 rounded-md px-3 py-3 transition hover:bg-gray-50"
            >
              <div>
                <h2
                  class="flex items-center gap-1.5 text-[15px] text-gray-700 group-hover:text-gray-900"
                >
                  <span>{post.data.title}</span>
                  <NewBadge pubDate={post.data.pubDate} />
                </h2>
                {post.data.description && (
                  <p class="mt-1 text-xs text-gray-400">
                    {post.data.description}
                  </p>
                )}
              </div>
              <time class="shrink-0 text-xs text-gray-400">
                {dayjs(post.data.pubDate).format("YYYY. MM. DD")}
              </time>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="py-20 text-center text-sm text-gray-400">
        No AI posts yet.
      </p>
    )
  }
</BaseLayout>
