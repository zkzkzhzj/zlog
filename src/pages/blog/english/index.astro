---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import { getBlogSlug, isPostCategory } from "../../../utils/content";

const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const posts = (await getCollection("blog"))
  .filter((post) => isPostCategory(post, "english") && !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="English · zlog">
  <h1 class="mb-6 text-2xl font-semibold">Blog</h1>

  <div class="mb-8 flex gap-2 border-b border-gray-200">
    <a
      href={`${base}blog/`}
      class="border-b-2 border-transparent px-3 py-2 text-sm text-gray-400 transition hover:text-gray-600"
    >
      General
    </a>
    <a
      href={`${base}blog/ai/`}
      class="border-b-2 border-transparent px-3 py-2 text-sm text-gray-400 transition hover:text-gray-600"
    >
      AI
    </a>
    <a
      href={`${base}blog/study/`}
      class="border-b-2 border-transparent px-3 py-2 text-sm text-gray-400 transition hover:text-gray-600"
    >
      Study
    </a>
    <a
      href={`${base}blog/english/`}
      class="border-b-2 border-gray-900 px-3 py-2 text-sm font-medium text-gray-900"
    >
      English
    </a>
    <a
      href={`${base}blog/book/`}
      class="border-b-2 border-transparent px-3 py-2 text-sm text-gray-400 transition hover:text-gray-600"
    >
      Book
    </a>
  </div>

  {
    posts.length > 0 ? (
      <ul class="flex flex-col gap-1">
        {posts.map((post) => (
          <li>
            <a
              href={`${base}blog/${getBlogSlug(post.id)}/`}
              class="group flex items-baseline justify-between gap-4 rounded-md px-3 py-3 transition hover:bg-gray-50"
            >
              <div>
                <h2 class="text-[15px] text-gray-700 group-hover:text-gray-900">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="mt-1 text-xs text-gray-400">
                    {post.data.description}
                  </p>
                )}
              </div>
              <time class="shrink-0 text-xs text-gray-400">
                {dayjs(post.data.pubDate).format("YYYY. MM. DD")}
              </time>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="py-20 text-center text-sm text-gray-400">
        No English posts yet.
      </p>
    )
  }
</BaseLayout>
