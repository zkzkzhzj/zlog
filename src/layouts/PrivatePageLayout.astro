---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const title = frontmatter.title ?? "Private";
const description = frontmatter.description ?? "Private page";
---

<BaseLayout title={title} description={description} noindex>
  <article data-pagefind-ignore>
    <header class="mb-8 border-b border-gray-100 pb-6">
      <p class="mb-2 text-xs font-medium tracking-wider text-gray-400 uppercase">
        Private
      </p>
      <h1 class="text-2xl font-semibold tracking-tight text-gray-950">
        {title}
      </h1>
      {description && <p class="mt-2 text-sm text-gray-500">{description}</p>}
    </header>
    <div class="prose-custom private-prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .private-prose {
    word-break: keep-all;
    overflow-wrap: anywhere;
  }

  .private-prose :global(table) {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
  }

  .private-prose :global(h2) {
    scroll-margin-top: 1rem;
  }
</style>
