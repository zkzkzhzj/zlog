---
import { getCollection, type CollectionEntry } from "astro:content";
import NewBadge from "../components/NewBadge.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = "zkzkzhzj의 블로그",
  ogImage,
  noindex = false,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const allPosts = (await getCollection("blog")).filter((post) => !post.data.draft);

function getLatestPubDate(
  predicate: (post: CollectionEntry<"blog">) => boolean,
) {
  return allPosts
    .filter(predicate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0]?.data
    .pubDate;
}

const latestBlogPubDate = getLatestPubDate(
  (post) => post.data.category !== "retro" && post.data.category !== "movie",
);
const latestRetroPubDate = getLatestPubDate(
  (post) => post.data.category === "retro",
);
const latestTastePubDate = getLatestPubDate(
  (post) => post.data.category === "movie",
);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {
      ogImage && (
        <meta property="og:image" content={new URL(ogImage, Astro.site)} />
      )
    }

    <!-- Search Console -->
    <meta name="google-site-verification" content="QL5oG6ROeQ_efrAdk4Xk9ZLbSRYdxWNyzD2FT7BFrmU" />

    <meta name="naver-site-verification" content="d38c673504a43b7081a895abd046ec7cfaba76c4" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HJR3WF26N4"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HJR3WF26N4');
    </script>

    <!-- Sitemap -->
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed"
      href={`${base}rss.xml`}
    />
  </head>
  <body class="flex min-h-screen flex-col bg-white text-gray-900">
    <header class="border-b border-gray-100">
      <nav
        class="mx-auto flex max-w-3xl items-center justify-between px-6 py-5"
      >
        <a href={base} class="text-lg font-semibold tracking-tight"
          >zlog</a
        >
        <div class="flex gap-6 text-sm text-gray-500">
          <a
            href={`${base}blog/`}
            class="flex items-center gap-1.5 transition hover:text-gray-900"
          >
            <span>Blog</span>
            {latestBlogPubDate && <NewBadge pubDate={latestBlogPubDate} />}
          </a>
          <a
            href={`${base}retro/`}
            class="flex items-center gap-1.5 transition hover:text-gray-900"
          >
            <span>Retro</span>
            {latestRetroPubDate && <NewBadge pubDate={latestRetroPubDate} />}
          </a>
          <a
            href={`${base}taste/`}
            class="flex items-center gap-1.5 transition hover:text-gray-900"
          >
            <span>Taste</span>
            {latestTastePubDate && <NewBadge pubDate={latestTastePubDate} />}
          </a>
          <a href={`${base}lab/`} class="transition hover:text-gray-900"
            >Lab</a
          >
        </div>
      </nav>
    </header>
    <main class="mx-auto w-full max-w-3xl flex-1 px-6 py-10">
      <slot />
    </main>
    <footer
      class="mt-auto border-t border-gray-100 py-6 text-center text-xs text-gray-400"
    >
      &copy; {new Date().getFullYear()} zlog
    </footer>
  </body>
</html>

<script>
  const DAY_IN_MS = 24 * 60 * 60 * 1000;
  const seoulDateFormatter = new Intl.DateTimeFormat("en-US", {
    timeZone: "Asia/Seoul",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  });

  function getTodayInSeoul() {
    const parts = seoulDateFormatter.formatToParts(new Date());
    const year = parts.find((part) => part.type === "year")?.value;
    const month = parts.find((part) => part.type === "month")?.value;
    const day = parts.find((part) => part.type === "day")?.value;

    return `${year}-${month}-${day}`;
  }

  function getDayNumber(dateString: string) {
    const [year, month, day] = dateString.split("-").map(Number);
    return Date.UTC(year, month - 1, day) / DAY_IN_MS;
  }

  const today = getDayNumber(getTodayInSeoul());

  document.querySelectorAll("[data-new-badge]").forEach((badge) => {
    const pubDate = badge.getAttribute("data-pub-date");
    if (!pubDate) return;

    const elapsedDays = today - getDayNumber(pubDate);
    if (elapsedDays >= 0 && elapsedDays <= 1) {
      badge.classList.remove("hidden");
      badge.classList.add("inline-grid");
    }
  });
</script>

<style is:global>
  @import "../styles/global.css";
</style>
